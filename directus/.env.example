# Directus local .env — copy values from root .env manually
# Docker Compose reads the root .env when run from project root.
# This file is for reference — fill in actual values, not ${VAR} references.

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
DB_PASSWORD=your-db-password
DIRECTUS_SECRET=your-directus-secret
DIRECTUS_TOKEN=your-directus-token
SERVER_IP=localhost
PORT_DIRECTUS=8056
PORT_POSTGRES=5433
PORT_REDIS=6380
