# Directus local .env — inherits values from root .env
# Copy root .env.example to .env first, then this file picks up vars.
# In Docker Compose, the root .env is auto-loaded when you run from the project root.

# These are referenced by docker-compose.yml via ${VAR:-default}
ADMIN_EMAIL=${ADMIN_EMAIL:-admin@example.com}
ADMIN_PASSWORD=${ADMIN_PASSWORD:-admin123}
DB_PASSWORD=${DB_PASSWORD:-directus123}
DIRECTUS_SECRET=${DIRECTUS_SECRET:-change-me}
DIRECTUS_TOKEN=${DIRECTUS_TOKEN:-docs-api-token-change-me}
SERVER_IP=${SERVER_IP:-localhost}
PORT_DIRECTUS=${PORT_DIRECTUS:-8056}
PORT_POSTGRES=${PORT_POSTGRES:-5433}
PORT_REDIS=${PORT_REDIS:-6380}
