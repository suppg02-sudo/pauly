###############################################################################
# Pauly — Central Configuration
# Copy this file to .env and adjust values. This is the SINGLE SOURCE OF TRUTH.
# All docker-compose files, Astro config, and scripts read from here.
# The setup script (scripts/detect-ports.sh) can auto-fill these.
###############################################################################

# ── Server ──────────────────────────────────────────────────────────────────
# The public IP or hostname of the server (for PUBLIC_URL, CORS, Astro site URL)
SERVER_IP=localhost

# ── Ports (ALL defined here — nothing else is hardcoded anywhere) ────────────
# Change these if you have port conflicts. Internal (container) ports are fixed.

# Directus: admin UI + REST API
PORT_DIRECTUS=8056

# Astro Starlight: the docs frontend
PORT_ASTRO=3003

# PostgreSQL (Directus database)
PORT_POSTGRES=5433

# Redis (Directus cache)
PORT_REDIS=6380

# ── Directus Internal (container-to-container — don't change) ────────────────
DIRECTUS_INTERNAL_PORT=8055
POSTGRES_INTERNAL_PORT=5432
REDIS_INTERNAL_PORT=6379
ASTRO_INTERNAL_PORT=4321

# ── Directus Credentials ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
DB_PASSWORD=directus123
# Generate with: openssl rand -hex 24
DIRECTUS_SECRET=CHANGE_ME_WITH_RANDOM_HEX
# Static API token (set after first boot, or generate: openssl rand -hex 16)
DIRECTUS_TOKEN=docs-api-token-change-me

# ── Docker Network ───────────────────────────────────────────────────────────
# Shared network name — both Directus and Astro must join this
DOCKER_NETWORK=directus_default
