---
import { fetchPageBySlug, formatDate } from '../../lib/directus';

export async function getStaticPaths() {
  return [];
}

const { slug } = Astro.params;
const page = await fetchPageBySlug(slug || '');

if (!page) {
  return Astro.redirect('/404');
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{page.title}</title>
  <meta name="description" content={page.excerpt || page.title} />
</head>
<body>
  <article class="sl-markdown-content">
    <h1>{page.title}</h1>
    {page.date_published && (
      <p class="date"><small>Published: {formatDate(page.date_published)}</small></p>
    )}
    <div set:html={page.content} />
    {page.tags && page.tags.length > 0 && (
      <div class="tags">
        {page.tags.map((tag: string) => <span class="tag">{tag}</span>)}
      </div>
    )}
  </article>
</body>
</html>
